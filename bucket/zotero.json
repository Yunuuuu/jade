{
    "version": "9.0.6",
    "description": "Open-source reference management software to manage bibliographic data and related research materials.",
    "homepage": "https://www.zotero.org/",
    "license": "AGPL-3.0-only",
    "url": "https://download.zotero.org/client/release/9.0.6/Zotero-9.0.6_win-x64.zip",
    "hash": "5101200aa900558d61abd6d0b4d504c8fb5b0e9edc9ee40f6d77bc21ec2eac9e",
    "extract_dir": "Zotero_win-x64",
    "bin": "zotero.exe",
    "shortcuts": [
        [
            "zotero.exe",
            "Zotero"
        ]
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $zotero_paths = @(",
        "        (Join-Path $env:APPDATA 'Zotero'),",
        "        (Join-Path $env:LOCALAPPDATA 'Zotero'),",
        "        (Join-Path $env:USERPROFILE 'Zotero')",
        "    )",
        "    foreach ($zotero_path in $zotero_paths) {",
        "        if (Test-Path $zotero_path) {",
        "            Write-Host \"Purging Zotero data: $zotero_path\"",
        "            Remove-Item -Recurse -Force $zotero_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://github.com/zotero/zotero/tags",
        "regex": "tag/(\\d+\\.\\d+\\.\\d+)"
    },
    "autoupdate": {
        "url": "https://download.zotero.org/client/release/$version/Zotero-$version_win-x64.zip",
        "hash": {
            "mode": "download"
        }
    }
}
