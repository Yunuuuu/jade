{
    "version": "26.3.27",
    "description": "A platform for building proxies to bypass network restrictions",
    "homepage": "https://github.com/XTLS/Xray-core",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://downloads.sourceforge.net/projects/xray-core.mirror/files/v26.3.27/Xray-windows-64.zip",
            "hash": "sha1:42e5e9a66b970b5499c34e99d8da6c986c67c2cc"
        },
        "32bit": {
            "url": "https://downloads.sourceforge.net/projects/xray-core.mirror/files/v26.3.27/Xray-windows-32.zip",
            "hash": "sha1:7b52fb53afe0bdc96276c4dc1112e8710395ad00"
        }
    },
    "post_install": [
        "if (!(test-path $persist_dir)) { New-Item -type directory $persist_dir > $null }",
        "if (!(Test-Path \"$persist_dir\\config.json\")) {",
        "    Set-Content \"$dir\\config.json\" '{}' -Encoding 'Ascii'",
        "}"
    ],
    "bin": "xray.exe",
    "persist": "config.json",
    "checkver": {
        "url": "https://sourceforge.net/projects/xray-core.mirror/rss?path=/",
        "regex": "v(\\d+\\.\\d+\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.sourceforge.net/projects/xray-core.mirror/files/v$version/Xray-windows-64.zip"
            },
            "32bit": {
                "url": "https://downloads.sourceforge.net/projects/xray-core.mirror/files/v$version/Xray-windows-32.zip"
            }
        }
    }
}
