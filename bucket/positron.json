{
    "version": "2026.06.0-211",
    "description": "Positron, a next-generation data science IDE.",
    "homepage": "https://positron.posit.co/",
    "license": "Elastic-2.0",
    "url": "https://cdn.posit.co/positron/releases/win/x86_64/Positron-2026.06.0-211-UserSetup-x64.exe",
    "hash": "6f86a50c9f257edaa7583da39919a7bd13f6b890c70dc3d53598e5118a528740",
    "notes": [
        "Please review Positron's license agreement (https://github.com/posit-dev/positron?tab=License-1-ov-file#readme).",
        "Your acceptance of this license agreement is required as a condition to proceeding with your use of the software.",
        "positron requires the latest versions of Microsoft Visual C++:",
        "    x86: `winget install --id Microsoft.VCRedist.2015+.x86`",
        "    x64: `winget install --id Microsoft.VCRedist.2015+.x64`",
        "    Arm64: `winget install --id Microsoft.VCRedist.2015+.arm64`"
    ],
    "installer": {
        "args": [
            "/VERYSILENT",
            "/DIR=$dir",
            "/NORESTART",
            "/TASKS=\"\""
        ]
    },
    "bin": "bin/positron.cmd",
    "shortcuts": [
        [
            "Positron.exe",
            "Positron"
        ]
    ],
    "uninstaller": {
        "file": "unins000.exe",
        "args": [
            "/VERYSILENT",
            "/NORESTART"
        ]
    },
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'Positron')",
        "        (Join-Path $env:LOCALAPPDATA 'Positron')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging Positron data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/posit-dev/positron",
        "regex": "\\/releases\\/tag\\/([\\d.\\-]+)"
    },
    "autoupdate": {
        "url": "https://cdn.posit.co/positron/releases/win/x86_64/Positron-$version-UserSetup-x64.exe",
        "hash": {
            "url": "https://cdn.posit.co/positron/releases/checksums/positron-$version-checksums.json",
            "jsonpath": "$.['Positron-$version-UserSetup-x64.exe']"
        }
    }
}
