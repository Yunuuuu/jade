{
    "version": "8.5.9.102",
    "description": "baidu netdisk client",
    "homepage": "http://pan.baidu.com/",
    "license": {
        "identifier": "Unknown",
        "url": "http://pan.baidu.com/disk/duty/"
    },
    "url": "http://wppkg.baidupcs.com/issue/netdisk/yunguanjia/BaiduNetdisk_8.5.9.102.exe#/dl.7z",
    "hash": "fd777350c1eb91b591a312a85d8c918e87e8216102840946f3a13a0a5311d804",
    "pre_install": [
        "$trash_paths = @(",
        "    (Join-Path $dir '$TEMP'),",
        "    (Join-Path $dir '$PLUGINSDIR')",
        ")",
        "foreach ($trash_path in $trash_paths) {",
        "    if (Test-Path $trash_path) {",
        "        Remove-Item -Recurse -Force $trash_path",
        "    }",
        "}"
    ],
    "post_install": [
        "$path = Join-Path $dir 'AutoUpdate\\config.ini'",
        "if (Test-Path $path) {",
        "    $content = Get-Content $path",
        "    $inSection = $false",
        "    $new = foreach ($line in $content) {",
        "        if ($line -match '^\\[AutoUpdate\\]') {",
        "            $inSection = $true",
        "            $line",
        "            continue",
        "        }",
        "        if ($line -match '^\\[') {",
        "            $inSection = $false",
        "        }",
        "        if ($inSection -and $line -match '^IsAutoUpdate\\s*=') {",
        "            'IsAutoUpdate=0'",
        "        } else {",
        "            $line",
        "        }",
        "    }",
        "    $out = $new -join \"`n\"",
        "    Set-Content -Path $path -Value $out",
        "} else {",
        "    Set-Content -Path $path '[AutoUpdate]`nIsAutoUpdate=0'",
        "}"
    ],
    "shortcuts": [
        [
            "BaiduNetdisk.exe",
            "Baidu Netdisk"
        ]
    ],
    "persist": "users",
    "pre_uninstall": [
        "Get-Process YunDetectService -ErrorAction SilentlyContinue | ForEach-Object {",
        "    Write-Host \"[BaiduNetdisk] killing YunDetectService process PID=$($_.Id)\"",
        "    Stop-Process -Id $_.Id -Force",
        "}"
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'Baidu\\BaiduYunKernel'),",
        "        (Join-Path $env:APPDATA 'BaiduYunGuanjia'),",
        "        (Join-Path $env:APPDATA 'BaiduYunKernel'),",
        "        (Join-Path $env:APPDATA 'baidunetdisk'),",
        "        (Join-Path $env:APPDATA 'PLogs'),",
        "        (Join-Path $env:LOCALAPPDATA 'BaiduYunGuanjia'),",
        "        (Join-Path $env:LOCALAPPDATA 'BaiduYunKernel')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging BaiduYunGuanjia data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "    if (-not (Test-Path -Path \"${env:APPDATA}\\Baidu\\*\")) {",
        "        Remove-Item \"${env:APPDATA}\\Baidu\" -Force -Recurse",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "http://pan.baidu.com/disk/cmsdata?do=client",
        "regex": "/yunguanjia/(?<name>Baidu[\\w]+_)(\\d+\\.\\d+\\.\\d+\\.\\d+)\\.exe"
    },
    "autoupdate": {
        "url": "http://wppkg.baidupcs.com/issue/netdisk/yunguanjia/$matchName$version.exe#/dl.7z",
        "hash": {
            "mode": "download"
        }
    }
}
