{
    "version": "8.6.3.101",
    "description": "baidu netdisk client",
    "homepage": "http://pan.baidu.com/",
    "license": {
        "identifier": "Unknown",
        "url": "http://pan.baidu.com/disk/duty/"
    },
    "url": "http://wppkg.baidupcs.com/issue/netdisk/yunguanjia/BaiduNetdisk_8.6.3.101.exe#/dl.7z",
    "hash": "36204b3a74bcd4f99212f7f5e91e12152ec403d8546fc7cef7fa636b7a583140",
    "pre_install": [
        "$trash_paths = @(",
        "    (Join-Path $dir '$TEMP'),",
        "    (Join-Path $dir '$PLUGINSDIR')",
        ")",
        "foreach ($trash_path in $trash_paths) {",
        "    if (Test-Path $trash_path) {",
        "        Remove-Item -Recurse -Force $trash_path",
        "    }",
        "}"
    ],
    "post_install": [
        "# turn off autoupdate",
        "$path = Join-Path $dir 'AutoUpdate\\config.ini'",
        "if (Test-Path $path) {",
        "    $content = Get-Content $path",
        "    $inSection = $false",
        "    $new = foreach ($line in $content) {",
        "        if ($line -match '^\\[AutoUpdate\\]') {",
        "            $inSection = $true",
        "            $line",
        "            continue",
        "        }",
        "        if ($line -match '^\\[') {",
        "            $inSection = $false",
        "        }",
        "        if ($inSection -and $line -match '^IsAutoUpdate\\s*=') {",
        "            'IsAutoUpdate=0'",
        "        } else {",
        "            $line",
        "        }",
        "    }",
        "    $out = $new -join \"`n\"",
        "    Set-Content -Path $path -Value $out",
        "} else {",
        "    Set-Content -Path $path '[AutoUpdate]`nIsAutoUpdate=0'",
        "}",
        "",
        "",
        "",
        "# turn off menu options",
        "$path = Join-Path $dir 'module\\BrowserEngine\\menu_option.ini'",
        "$settings = [ordered]@{",
        "    ShowPcNaUploadFile = '0'",
        "    ShowPdfToOffice = '0'",
        "    ShowExcelToPdf = '0'",
        "    ShowPptToPdf = '0'",
        "    ShowWordToPdf = '0'",
        "    ShowImageToOffice = '0'",
        "    ShowListenNote = '0'",
        "    ShowAutobackupDir = '0'",
        "    ShowMoveToSync = '0'",
        "    ShowCloudPrint = '0'",
        "}",
        "$parent = Split-Path -Parent $path",
        "if (-not (Test-Path -LiteralPath $parent)) {",
        "    New-Item -ItemType Directory -Path $parent -Force | Out-Null",
        "}",
        "$content = if (Test-Path -LiteralPath $path) {",
        "    @(Get-Content -LiteralPath $path)",
        "} else {",
        "    @()",
        "}",
        "$out = [System.Collections.Generic.List[string]]::new()",
        "$seen = @{}",
        "$inSection = $false",
        "$sectionFound = $false",
        "foreach ($line in $content) {",
        "    if ($line -match '^\\s*\\[(.+?)\\]\\s*$') {",
        "        if ($inSection) {",
        "            foreach ($key in $settings.Keys) {",
        "                if (-not $seen.ContainsKey($key)) {",
        "                    $out.Add(\"$key=$($settings[$key])\")",
        "                }",
        "            }",
        "        }",
        "        $inSection = ($Matches[1] -ieq 'LOCAL_MENU_OPTION')",
        "        if ($inSection) {",
        "            $sectionFound = $true",
        "            $seen = @{}",
        "        }",
        "        $out.Add($line)",
        "        continue",
        "    }",
        "    if ($inSection -and $line -match '^\\s*([A-Za-z0-9_]+)\\s*=') {",
        "        $key = $Matches[1]",
        "        if ($settings.Contains($key)) {",
        "            if (-not $seen.ContainsKey($key)) {",
        "                $out.Add(\"$key=$($settings[$key])\")",
        "                $seen[$key] = $true",
        "            }",
        "            continue",
        "        }",
        "    }",
        "    $out.Add($line)",
        "}",
        "if ($inSection) {",
        "    foreach ($key in $settings.Keys) {",
        "        if (-not $seen.ContainsKey($key)) {",
        "            $out.Add(\"$key=$($settings[$key])\")",
        "        }",
        "    }",
        "}",
        "if (-not $sectionFound) {",
        "    if ($out.Count -gt 0 -and $out[$out.Count - 1] -ne '') {",
        "        $out.Add('')",
        "    }",
        "    $out.Add('[LOCAL_MENU_OPTION]')",
        "    foreach ($key in $settings.Keys) {",
        "        $out.Add(\"$key=$($settings[$key])\")",
        "    }",
        "}",
        "Set-Content -LiteralPath $path -Value ($out -join \"`n\")"
    ],
    "shortcuts": [
        [
            "BaiduNetdisk.exe",
            "Baidu Netdisk"
        ]
    ],
    "persist": "users",
    "pre_uninstall": [
        "Get-Process YunDetectService -ErrorAction SilentlyContinue | ForEach-Object {",
        "    Write-Host \"[BaiduNetdisk] killing YunDetectService process PID=$($_.Id)\"",
        "    Stop-Process -Id $_.Id -Force",
        "}"
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'Baidu\\BaiduYunKernel'),",
        "        (Join-Path $env:APPDATA 'BaiduYunGuanjia'),",
        "        (Join-Path $env:APPDATA 'BaiduYunKernel'),",
        "        (Join-Path $env:APPDATA 'baidunetdisk'),",
        "        (Join-Path $env:APPDATA 'PLogs'),",
        "        (Join-Path $env:LOCALAPPDATA 'BaiduYunGuanjia'),",
        "        (Join-Path $env:LOCALAPPDATA 'BaiduYunKernel')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging BaiduYunGuanjia data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "    if (-not (Test-Path -Path \"${env:APPDATA}\\Baidu\\*\")) {",
        "        Remove-Item \"${env:APPDATA}\\Baidu\" -Force -Recurse",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "http://pan.baidu.com/disk/cmsdata?do=client",
        "regex": "/yunguanjia/(?<name>Baidu[\\w]+_)(\\d+\\.\\d+\\.\\d+\\.\\d+)\\.exe"
    },
    "autoupdate": {
        "url": "http://wppkg.baidupcs.com/issue/netdisk/yunguanjia/$matchName$version.exe#/dl.7z",
        "hash": {
            "mode": "download"
        }
    }
}
