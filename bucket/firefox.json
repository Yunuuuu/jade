{
    "version": "152.0.4",
    "description": "Popular open source web browser.",
    "homepage": "https://www.mozilla.org/firefox/",
    "license": "MPL-2.0",
    "architecture": {
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/152.0.4/win32/en-US/Firefox%20Setup%20152.0.4.exe#/dl.7z",
            "hash": "sha512:fc5509357fec5e0329ceacae0ea169293fc25588228a37622ba5f5e68b87cea4c8eb36059b358406b64070c8d242f0cf9ae82cda60f5010ff777c712c81297ca"
        },
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/152.0.4/win64/en-US/Firefox%20Setup%20152.0.4.exe#/dl.7z",
            "hash": "sha512:0cd81f62f658572ab41cdb47ff1a0a0d184ef1a19dd1577ca213fcb5a2843d8ef9ccfbddebcbdaa8455ba5c6de2e0707736f54a0c2d8b4d7fceecce93d6152cd"
        },
        "arm64": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/152.0.4/win64-aarch64/en-US/Firefox%20Setup%20152.0.4.exe#/dl.7z",
            "hash": "sha512:6e5a95a5c035b6a897c63e67f013a1b69ca69af64296ccefc67afc7daf0461df60af3a5c6356587638de2defd78884ccd716ce0144d9984018edb1cc253b9c82"
        }
    },
    "extract_dir": "core",
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox"
        ],
        [
            "firefox.exe",
            "Firefox Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'Firefox'),",
        "        (Join-Path $env:LOCALAPPDATA 'Firefox')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging Firefox data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://www.mozilla.org/en-US/firefox/releasenotes/",
        "regex": "(\\d+\\.\\d+\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            },
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "arm64": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64-aarch64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64-aarch64/en-US/$basename"
                }
            }
        }
    }
}
