{
    "version": "152.0.3",
    "description": "Popular open source web browser.",
    "homepage": "https://www.mozilla.org/firefox/",
    "license": "MPL-2.0",
    "architecture": {
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/152.0.3/win32/en-US/Firefox%20Setup%20152.0.3.exe#/dl.7z",
            "hash": "sha512:a53115bdaa91fc65fe16426ddabfe638f946cdcdcd0c68d32f6db3002d665d912e5ccbae446dae5b41ed133de16a451436c042a76d103761bf32dc104e33b3b4"
        },
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/152.0.3/win64/en-US/Firefox%20Setup%20152.0.3.exe#/dl.7z",
            "hash": "sha512:0a2e78c5c4dd7cb1e694e86b390d4c996cb1e1af155d913990363d5081b9210942213bffd53ee706466065d4ff993efeced25caf5b8ea9aad498197c861ead8f"
        },
        "arm64": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/152.0.3/win64-aarch64/en-US/Firefox%20Setup%20152.0.3.exe#/dl.7z",
            "hash": "sha512:d744d78825bf3cd1fff873ad7f36b6d985041cf9cee820cf2386022c9af91d9bfaa6d3bcda98d75f5ed1fb3096d230b9eb598b8acd7d3dc8422ea0ff8b0a58e9"
        }
    },
    "extract_dir": "core",
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox"
        ],
        [
            "firefox.exe",
            "Firefox Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'Firefox'),",
        "        (Join-Path $env:LOCALAPPDATA 'Firefox')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging Firefox data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://www.mozilla.org/en-US/firefox/releasenotes/",
        "regex": "(\\d+\\.\\d+\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            },
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "arm64": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64-aarch64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64-aarch64/en-US/$basename"
                }
            }
        }
    }
}
