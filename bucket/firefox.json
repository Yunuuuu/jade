{
    "version": "152.0.2",
    "description": "Popular open source web browser.",
    "homepage": "https://www.mozilla.org/firefox/",
    "license": "MPL-2.0",
    "architecture": {
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/152.0.2/win32/en-US/Firefox%20Setup%20152.0.2.exe#/dl.7z",
            "hash": "sha512:43b2a0c8b9339dd372eb534e1856768832938856cb6eb41d506d76444ec196cce6234419568402b51969278b1054a4e4d0e8bbb78900e272b4ec5eeafb7b975a"
        },
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/152.0.2/win64/en-US/Firefox%20Setup%20152.0.2.exe#/dl.7z",
            "hash": "sha512:41f2ad248b8a378d8c3a7bc1edc00d62a9bdaee76a91628fa4324d28ce4ba60aa744339f44942fbd7051ffea65ab5dbf16fb8a1d4993c29f76f92958d396da1c"
        },
        "arm64": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/152.0.2/win64-aarch64/en-US/Firefox%20Setup%20152.0.2.exe#/dl.7z",
            "hash": "sha512:08b982dd3d557a100e0167bbb8b47e59fe94f06aab07d7d19fc233a38a16ec18714a45784613010275dfe68951380b20a426121b9dada90457a5799a02430a01"
        }
    },
    "extract_dir": "core",
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox"
        ],
        [
            "firefox.exe",
            "Firefox Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'Firefox'),",
        "        (Join-Path $env:LOCALAPPDATA 'Firefox')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging Firefox data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://www.mozilla.org/en-US/firefox/releasenotes/",
        "regex": "(\\d+\\.\\d+\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            },
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "arm64": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64-aarch64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64-aarch64/en-US/$basename"
                }
            }
        }
    }
}
