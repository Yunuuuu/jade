        }
    },
    "installer": {
        "script": [
            "if (!(test-path $persist_dir)) { New-Item -type directory $persist_dir > $null }",
            "$persist_item = Join-Path $persist_dir 'config.json'",
            "if (!(Test-Path $persist_item)) {",
            "    $source_item  = Join-Path $dir 'config.json'",
            "    if (Test-Path $source_item) {",
            "        Move-Item -Path $source_item -Destination $persist_item",
            "    } else {",
            "        New-Item -ItemType File -Path $persist_item | Out-Null",
            "    }",
            "}"
        ]
    },
    "bin": "godns.exe",
    "persist": "config.json",
    "checkver": {
        "github": "https://github.com/TimothyYe/godns"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://github.com/TimothyYe/godns/releases/download/v$version/godns_$version_Windows_386.tar.gz",
                "hash": {
                    "url": "https://github.com/TimothyYe/godns/releases/download/v$version/checksums.txt",
                    "find": "([a-fA-F0-9]{64})\\s*godns_$version_windows_386.tar.gz"
                }
            },
            "64bit": {
                "url": "https://github.com/TimothyYe/godns/releases/download/v$version/godns_$version_Windows_amd64.tar.gz",
                "hash": {
                    "url": "https://github.com/TimothyYe/godns/releases/download/v$version/checksums.txt",
                    "find": "([a-fA-F0-9]{64})\\s*godns_$version_windows_amd64.tar.gz"
                }
            },
            "arm64": {
                "url": "https://github.com/TimothyYe/godns/releases/download/v$version/godns_$version_Windows_arm64.tar.gz",
                "hash": {
                    "url": "https://github.com/TimothyYe/godns/releases/download/v$version/checksums.txt",
                    "find": "([a-fA-F0-9]{64})\\s*godns_$version_windows_arm64.tar.gz"
                }
            }
        }
    }
}
