{
    "version": "1.3.3",
    "description": "A fork of the discontinued Switch emulator, Ryujinx.",
    "homepage": "https://git.ryujinx.app/projects/Ryubing",
    "license": "MIT",
    "notes": [
        "ATTENTION: Ryujinx requires Nintendo Switch firmware and a prod.keys file to function.",
        "Learn more at https://docs.ryujinx.app/guides/setup-guide/",
        "Following site may be useful, use them at your own risk:",
        "  1. https://theprodkeys.com/vi/",
        "  2. https://prodkeys.net/"
    ],
    "architecture": {
        "64bit": {
            "url": "https://git.ryujinx.app/projects/Ryubing/releases/download/1.3.3/ryujinx-1.3.3-win_x64.zip",
            "hash": "baa93f48b012eefeca339a78a39844599ccd194c109093f354a4b9d1e03a056e"
        }
    },
    "extract_dir": "publish",
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-Item \"$persist_dir\\portable\" -ItemType Directory | Out-Null",
        "   if (Test-Path \"$env:APPDATA\\Ryujinx\") {",
        "       Write-host \"Migrating AppData...\" -ForegroundColor yellow",
        "       Copy-Item -Path \"$env:APPDATA\\Ryujinx\\*\" -Destination \"$persist_dir\\portable\" -Recurse",
        "       Remove-Item -Path \"$env:APPDATA\\Ryujinx\" -Recurse",
        "   }",
        "}"
    ],
    "bin": [
        [
            "Ryujinx.exe",
            "ryubing"
        ]
    ],
    "shortcuts": [
        [
            "Ryujinx.exe",
            "Ryubing"
        ]
    ],
    "persist": "portable",
    "checkver": {
        "url": "https://git.ryujinx.app/projects/Ryubing/releases/latest",
        "regex": "releases/tag/([0-9.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://git.ryujinx.app/projects/Ryubing/releases/download/$version/ryujinx-$version-win_x64.zip"
            }
        }
    }
}
