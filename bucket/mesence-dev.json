{
    "version": "716-20260721-4f18f37",
    "homepage": "https://github.com/nesdev-org/MesenCE",
    "license": "GPL-3.0",
    "description": [
        "Mesen is a multi-system emulator for Windows, Linux, and macOS. It supports NES, SNES, Game Boy (GB/SGB/GBC), Game Boy Advance, PC Engine, SMS/Game Gear, and WonderSwan (WS/WSC)",
        "",
        "MesenCE is a community-managed fork based on Mesen2, created to maintain and expand this emulator into the future."
    ],
    "notes": "MesenCE requires the DotNet Runtime 6.0: `winget install --id Microsoft.DotNet.Runtime.6`",
    "url": "https://nightly.link/nesdev-org/MesenCE/suites/80678699360/artifacts/8480258642",
    "hash": "2a14c64ac2d1dc266abd4b73e1e1f51e34644ac308177dbc7fe22380b68a2740",
    "installer": {
        "script": [
            "if (!(test-path $persist_dir)) { New-Item -ItemType directory $persist_dir > $null }",
            "$file_items = @(",
            "    'MesenNesDB.txt',",
            "    'settings.json'",
            ")",
            "foreach ($item in $file_items) {",
            "    $persist_item = Join-Path $persist_dir $item",
            "    if (!(Test-Path $persist_item)) {",
            "        $source_item  = Join-Path $dir $item",
            "        if (Test-Path $source_item) {",
            "            Move-Item -Path $source_item -Destination $persist_item",
            "        } else {",
            "            New-Item -ItemType File -Path $persist_item | Out-Null",
            "        }",
            "    }",
            "}"
        ]
    },
    "shortcuts": [
        [
            "Mesen.exe",
            "MesenCE-dev"
        ]
    ],
    "persist": [
        "Cheats",
        "Debugger",
        "GameConfig",
        "HdPacks",
        "RecentGames",
        "Satellaview",
        "Saves",
        "SaveStates",
        "MesenNesDB.txt",
        "settings.json"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/nesdev-org/MesenCE/actions/workflows/build.yml/runs?event=push&branch=master&status=success",
        "script": [
            "$run = (ConvertFrom-Json $page).workflow_runs[0]",
            "$artifacts = (Invoke-WebRequest -UseBasicParsing $run.artifacts_url).Content | ConvertFrom-Json",
            "$artifact = $artifacts.artifacts | Where-Object { $_.name -match 'Windows.*AoT' } | Select-Object -First 1",
            "if (!$artifact) { throw 'Could not find the Windows AoT artifact' }",
            "$run_number = $run.run_number",
            "$date = [datetime]$run.created_at",
            "$commit = $run.head_sha.Substring(0, 7)",
            "$version = '{0}-{1:yyyyMMdd}-{2}' -f $run_number, $date, $commit",
            "$artifact_url = 'https://nightly.link/nesdev-org/MesenCE/suites/{0}/artifacts/{1}' -f $run.check_suite_id, $artifact.id",
            "$artifact_api_url = $artifact.url",
            "Write-Output \"$version $artifact_url $artifact_api_url\""
        ],
        "regex": "^(?<Version>[^ ]+) (?<Url>https://[^ ]+) (?<Artifact>https://[^ ]+)"
    },
    "autoupdate": {
        "url": "$matchUrl",
        "hash": {
            "url": "$matchArtifact",
            "jsonpath": "$.digest"
        }
    }
}
