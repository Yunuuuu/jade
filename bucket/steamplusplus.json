{
    "version": "3.1.0",
    "homepage": "https://github.com/BeyondDimension/SteamTools/",
    "description": "Watt Toolkit, 原名 Steam++, 是一个开源跨平台的多功能游戏工具箱, 此工具的大部分功能都是需要您下载安装 Steam 才能使用。",
    "license": "GPL-3.0-only",
    "url": "https://github.com/BeyondDimension/SteamTools/releases/download/3.1.0/Steam%2B%2B_v3.1.0_win_x64.7z",
    "hash": "74d0eb1fd67e8eb0914a9962244fc4251993061df77e6e6c0dfe8a4a899d5ae4",
    "bin": "Steam++.exe",
    "shortcuts": [
        [
            "Steam++.exe",
            "Steam++"
        ]
    ],
    "persist": [
        "AppData",
        "Cache",
        "Logs"
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $certs = Get-ChildItem Cert:\\LocalMachine\\Root -ErrorAction SilentlyContinue | Where-Object { $_.Subject -match 'SteamTools|Watt' }",
        "    if ($certs) {",
        "        Write-Host \"Purging $app certificates\"",
        "        $isAdmin = [Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent().IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)",
        "        if ($isAdmin) {",
        "            $certs | Remove-Item -ErrorAction SilentlyContinue",
        "        } else {",
        "            $thumbprints = $certs.Thumbprint -join ','",
        "            $cmd = \"'$thumbprints'.Split(',') | ForEach-Object { Remove-Item `\"Cert:\\LocalMachine\\Root\\`$_`\" -ErrorAction SilentlyContinue }\"",
        "            Start-Process powershell -ArgumentList \"-NoProfile -WindowStyle Hidden -Command $cmd\" -Verb RunAs -Wait",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/BeyondDimension/SteamTools/releases/latest",
        "script": [
            "$assets = json_path $page '$.assets[?(@.name =~ /win.*\\.7z$/)]'",
            "$url = json_path $assets '$.browser_download_url'",
            "$version = json_path $page '$.tag_name'",
            "Write-Output \"$version $url\""
        ],
        "regex": "^(?<Version>[^ ]+) (?<Url>https://.+\\.7z)$",
        "replace": "${Version}"
    },
    "autoupdate": {
        "url": "$matchUrl"
    }
}
