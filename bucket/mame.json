{
    "version": "mame0280",
    "description": "Arcade machine emulator",
    "homepage": "http://mamedev.org",
    "license": {
        "identifier": "GPL-2.0",
        "url": "https://github.com/mamedev/mame/blob/master/COPYING"
    },
    "notes": [
        "Learn more at https://docs.mamedev.org/",
        "Following site may be useful, use them at your own risk:",
        "  1. https://www.planetemu.net/machine/mame",
        "  2. https://archive.org/details/mame-merged"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/mamedev/mame/releases/download/mame0280/mame0280b_64bit.exe#/dl.7z",
            "hash": "67cb5049e497fcd551ca052d815ba4a581435f49d405b501c6ac01ec7610073d"
        }
    },
    "post_install": [
        "if (!(test-path $persist_dir)) { New-Item -type directory $persist_dir > $null }",
        "$items = @(",
        "    'roms','hash','samples','artwork','ctrlr','ini','font','cheat','crosshair','plugins','language','software',",
        "    'history','folders','cabinets','cabdevs','cpanel','pcb','flyers','titles','ends','marquees',",
        "    'artwork preview','bosses','logo','scores','versus','gameover','howto','select','icons','covers'",
        ")",
        "foreach ($item in $items) {",
        "    $persist_item = Join-Path $persist_dir $item",
        "    $source_item  = Join-Path $dir $item",
        "    if (!(Test-Path $persist_item)) {",
        "        if (Test-Path $source_item) {",
        "            Move-Item -Path $source_item -Destination $persist_item",
        "        } else {",
        "            New-Item -ItemType Directory -Path $persist_item | Out-Null",
        "        }",
        "    }",
        "}",
        "if ($global) {",
        "    $app_dir = \"$globaldir\\apps\\$app\\current\"",
        "} else {",
        "    $app_dir = \"$scoopdir\\apps\\$app\\current\"",
        "}",
        "$app_dir = \"$app_dir\".Replace('\\', '/')",
        "if (!(Test-Path \"$persist_dir\\ini\\mame.ini\")) {",
        "    $main_content = Get-Content \"$bucketsdir\\jade\\config\\mame\\mame.ini\"",
        "    $main_content = $main_content.Replace('$app_dir', $app_dir)",
        "    Set-Content -Path \"$persist_dir\\ini\\mame.ini\" -value $main_content",
        "}",
        "if (!(test-path \"$persist_dir\\ini\\ui.ini\")) { ",
        "    $ui_content = Get-Content \"$bucketsdir\\jade\\config\\mame\\ui.ini\"",
        "    $ui_content = $ui_content.Replace('$app_dir', $app_dir)",
        "    Set-Content -Path \"$persist_dir\\ini\\ui.ini\" -value $ui_content",
        "}"
    ],
    "bin": [
        [
            "mame.exe",
            "mame",
            "-inipath .;ini;%USERPROFILE%/.config/mame/ini;%APPDATA%/mame;%LOCALAPPDATA%/mame/ini;$dir/ini;$dir/ini/presets"
        ],
        [
            "chdman.exe",
            "chdman"
        ]
    ],
    "persist": [
        "roms", "hash", "samples", "artwork", "ctrlr", "ini", "font", "cheat", "crosshair", "plugins", "language", "software",
        "history", "folders", "cabinets", "cabdevs", "cpanel", "pcb", "flyers", "titles", "ends", "marquees", 
        "artwork preview", "bosses", "logo", "scores", "versus", "gameover", "howto", "select", "icons", "covers"
    ],
    "shortcuts": [
        [
            "mame.exe",
            "MAME",
            "-inipath .;ini;%USERPROFILE%/.config/mame/ini;%APPDATA%/mame;%LOCALAPPDATA%/mame/ini;$dir/ini;$dir/ini/presets"
        ]
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:USERPROFILE '.config\\mame'),",
        "        (Join-Path $env:APPDATA 'mame'),",
        "        (Join-Path $env:LOCALAPPDATA 'mame')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging mame data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/mamedev/mame",
        "regex": "\\/releases\\/tag\\/([\\d.a-zA-Z]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mamedev/mame/releases/download/$version/$versionb_64bit.exe#/dl.7z",
                "hash": {
                    "url": "https://github.com/mamedev/mame/releases/download/$version/SHA256SUMS"
                }
            }
        }
    }
}
