{
    "version": "4.15",
    "description": "A utility that helps format and create bootable USB flash drives.",
    "homepage": "https://rufus.ie/",
    "license": "GPL-3.0-only",
    "url": "https://github.com/pbatard/rufus/releases/download/v4.15/rufus-4.15p.exe#/rufus.exe",
    "hash": "84c8a437f8af89257524478489e5c85f1edf25f761d299e2bcde46ac0afbe106",
    "installer": {
        "script": [
            "if (!(test-path $persist_dir)) { New-Item -ItemType directory $persist_dir > $null }",
            "$dir_items = @(",
            "    'rufus_files'",
            ")",
            "foreach ($item in $dir_items) {",
            "    $persist_item = Join-Path $persist_dir $item",
            "    if (!(Test-Path $persist_item)) {",
            "        $source_item  = Join-Path $dir $item",
            "        if (Test-Path $source_item) {",
            "            Move-Item -Path $source_item -Destination $persist_item",
            "        } else {",
            "            New-Item -ItemType Directory -Path $persist_item | Out-Null",
            "        }",
            "    }",
            "}",
            "$file_items = @(",
            "    'rufus.ini'",
            ")",
            "foreach ($item in $file_items) {",
            "    $persist_item = Join-Path $persist_dir $item",
            "    if (!(Test-Path $persist_item)) {",
            "        $source_item  = Join-Path $dir $item",
            "        if (Test-Path $source_item) {",
            "            Move-Item -Path $source_item -Destination $persist_item",
            "        } else {",
            "            New-Item -ItemType File -Path $persist_item | Out-Null",
            "        }",
            "    }",
            "}"
        ]
    },
    "shortcuts": [
        [
            "rufus.exe",
            "Rufus"
        ]
    ],
    "persist": [
        "rufus.ini",
        "rufus_files"
    ],
    "checkver": {
        "github": "https://github.com/pbatard/rufus"
    },
    "autoupdate": {
        "url": "https://github.com/pbatard/rufus/releases/download/v$version/rufus-$versionp.exe#/rufus.exe"
    }
}
