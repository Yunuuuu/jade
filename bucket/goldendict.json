{
    "version": "1.5.1",
    "description": "A feature-rich dictionary lookup program",
    "homepage": "https://github.com/goldendict/goldendict",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/goldendict/goldendict/releases/download/1.5.1/GoldenDict-1.5.1_.QT_5123.64bit.7z",
            "hash": "a8102e777e6aa63b84a1ab4f398536aed90c677b542d4f52b1b2c4fdcbf7dc2c"
        },
        "32bit": {
            "url": "https://github.com/goldendict/goldendict/releases/download/1.5.1/GoldenDict-1.5.1_.QT_5123.7z",
            "hash": "82c4017a31e3b038eb9517a712602fc94c96d74c7494dc41265404861b629622"
        }
    },
    "extract_dir": "GoldenDict",
    "bin": "GoldenDict.exe",
    "shortcuts": [
        [
            "GoldenDict.exe",
            "GoldenDict"
        ]
    ],
    "persist": "content",
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'GoldenDict'),",
        "        (Join-Path $env:LOCALAPPDATA 'GoldenDict')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging GoldenDict data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/goldendict/goldendict/releases/latest",
        "script": [
            "$version = json_path $page '$.tag_name'",
            "$assets = json_path $page '$.assets[?(@.name =~ /\\.7z$/)]'",
            "$name_64bit = json_path $assets '$[?(@.name =~ /\\.64bit\\.7z$/)].name'",
            "$name_32bit = $name_64bit -replace '\\.64bit', ''",
            "$url_32bit = json_path $assets \"$[?(@.name == '$name_32bit')].browser_download_url\"",
            "$url_64bit = json_path $assets \"$[?(@.name == '$name_64bit')].browser_download_url\"",
            "Write-Output \"$version $url_32bit $url_64bit\""
        ],
        "regex": "^(?<Version>[\\d.]+) (?<Url32bit>https://.+\\.7z) (?<Url64bit>https://.+\\.7z)$",
        "replace": "${Version}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchUrl64bit",
                "hash": {
                    "mode": "download"
                }
            },
            "32bit": {
                "url": "$matchUrl32bit",
                "hash": {
                    "mode": "download"
                }
            }
        }
    }
}
