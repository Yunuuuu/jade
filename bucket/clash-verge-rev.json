{
    "version": "2.5.2",
    "description": "Continuation of Clash Verge - A Clash Meta GUI based on Tauri.",
    "homepage": "https://github.com/clash-verge-rev/clash-verge-rev",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://downloads.sourceforge.net/projects/clash-verge-rev.mirror/files/v2.5.2/Clash.Verge_2.5.2_x64-setup.exe#/dl.7z",
            "hash": "sha1:ca1b5064eafcb90ecea4ead35959b85d18760035"
        },
        "arm64": {
            "url": "https://downloads.sourceforge.net/projects/clash-verge-rev.mirror/files/v2.5.2/Clash.Verge_2.5.2_arm64-setup.exe#/dl.7z",
            "hash": "sha1:b5062df3ade4bc6e9e3fc06f07f015d90637e4f5"
        }
    },
    "pre_install": [
        "$trash_paths = @(",
        "    (Join-Path $dir '$TEMP'),",
        "    (Join-Path $dir '$PLUGINSDIR')",
        ")",
        "foreach ($trash_path in $trash_paths) {",
        "    if (Test-Path $trash_path) {",
        "        Remove-Item -Recurse -Force $trash_path",
        "    }",
        "}"
    ],
    "shortcuts": [
        [
            "clash-verge.exe",
            "Clash Verge"
        ]
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'io.github.clash-verge-rev.clash-verge-rev'),",
        "        (Join-Path $env:LOCALAPPDATA 'io.github.clash-verge-rev.clash-verge-rev')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging clash-verge-rev data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://sourceforge.net/projects/clash-verge-rev.mirror/rss?path=/",
        "regex": "v(\\d+\\.\\d+\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.sourceforge.net/projects/clash-verge-rev.mirror/files/v$version/Clash.Verge_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://downloads.sourceforge.net/projects/clash-verge-rev.mirror/files/v$version/Clash.Verge_$version_arm64-setup.exe#/dl.7z"
            }
        }
    }
}
