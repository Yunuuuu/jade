{
    "version": "0.71.1",
    "description": "Package management made easy",
    "homepage": "https://pixi.sh",
    "license": "BSD-3-Clause",
    "architecture": {
        "64bit": {
            "url": "https://github.com/prefix-dev/pixi/releases/download/v0.71.1/pixi-x86_64-pc-windows-msvc.zip",
            "hash": "6b6692588ac67a38ac4804ad1e7e41f838cce9cbe61686649576f0ee307968bc"
        },
        "arm64": {
            "url": "https://github.com/prefix-dev/pixi/releases/download/v0.71.1/pixi-aarch64-pc-windows-msvc.zip",
            "hash": "1a6717aa71b777015242d43e6059bb2507f0fccd9be1efd78d89aa75c1c76827"
        }
    },
    "bin": "pixi.exe",
    "env_set": {
        "PIXI_CACHE_DIR": "$persist_dir\\cache",
        "PIXI_HOME": "$persist_dir"
    },
    "post_install": "Add-Path -Path $persist_dir\\bin -Global:$global",
    "post_uninstall": [
        "Remove-Path -Path $dir\\bin -Global:$global",
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'pixi'),",
        "        (Join-Path $env:LocalAppData 'pixi')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging pixi data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/prefix-dev/pixi"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/prefix-dev/pixi/releases/download/v$version/pixi-x86_64-pc-windows-msvc.zip",
                "hash": {
                    "url": "$url.sha256"
                }
            },
            "arm64": {
                "url": "https://github.com/prefix-dev/pixi/releases/download/v$version/pixi-aarch64-pc-windows-msvc.zip",
                "hash": {
                    "url": "$url.sha256"
                }
            }
        }
    }
}
