{
    "version": "0.70.2",
    "description": "Package management made easy",
    "homepage": "https://pixi.sh",
    "license": "BSD-3-Clause",
    "architecture": {
        "64bit": {
            "url": "https://github.com/prefix-dev/pixi/releases/download/v0.70.2/pixi-x86_64-pc-windows-msvc.zip",
            "hash": "90bab8eb79031ae406119dc33ca24bc680a17b05364b96174c5d74a26563509c"
        },
        "arm64": {
            "url": "https://github.com/prefix-dev/pixi/releases/download/v0.70.2/pixi-aarch64-pc-windows-msvc.zip",
            "hash": "a78ac461ff417cc235c8d627fd760efa6fcf2b516a0e620a6a960f02f876f341"
        }
    },
    "bin": "pixi.exe",
    "env_set": {
        "PIXI_NO_PATH_UPDATE": "true"
    },
    "post_install": [
        "if ($global) {",
        "    $pixi_home = Join-Path $env:ProgramData 'pixi'",
        "} else {",
        "    $pixi_home = Join-Path $env:LocalAppData 'pixi'",
        "}",
        "Write-Host \"Setting environment variable PIXI_HOME to $pixi_home\"",
        "Set-EnvVar -Name 'PIXI_HOME' -Value $pixi_home -Global:$global",
        "$pixi_bin = Join-Path $pixi_home 'bin'",
        "Add-Path -Path $pixi_bin -Global:$global",
        "if (!(Test-Path $pixi_home)) { New-Item -ItemType Directory -Force $pixi_home | Out-Null }",
        "if (!(Test-Path $pixi_bin)) { New-Item -ItemType Directory -Force $pixi_bin | Out-Null }"
    ],
    "post_uninstall": [
        "Write-Host \"Removing environment variable PIXI_HOME\"",
        "Set-EnvVar -Name 'PIXI_HOME' -Value $null -Global:$global",

        "if ($global) {",
        "    $pixi_home = Join-Path $env:ProgramData 'pixi'",
        "} else {",
        "    $pixi_home = Join-Path $env:LocalAppData 'pixi'",
        "}",
        "$pixi_bin = Join-Path $pixi_home 'bin'",
        "Remove-Path -Path $pixi_bin -Global:$global",

        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'pixi'),",
        "        (Join-Path $env:LocalAppData 'pixi')",
        "    )",
        "    if ($global) {",
        "        $app_paths += Join-Path $env:ProgramData 'pixi'",
        "    }",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging pixi data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/prefix-dev/pixi"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/prefix-dev/pixi/releases/download/v$version/pixi-x86_64-pc-windows-msvc.zip",
                "hash": {
                    "url": "$url.sha256"
                }
            },
            "arm64": {
                "url": "https://github.com/prefix-dev/pixi/releases/download/v$version/pixi-aarch64-pc-windows-msvc.zip",
                "hash": {
                    "url": "$url.sha256"
                }
            }
        }
    }
}
