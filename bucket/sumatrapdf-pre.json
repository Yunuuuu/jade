    "architecture": {
        "64bit": {
            "url": "https://www.sumatrapdfreader.org/dl/prerel/20054/SumatraPDF-prerel-64.exe",
            "hash": "5d7a8bc9f9fbfe3a45d05a4b7a30a8df8f948a1b34b39a0f5a674680338e5ff5"
        },
        "arm64": {
            "url": "https://www.sumatrapdfreader.org/dl/prerel/20054/SumatraPDF-prerel-arm64.exe",
            "hash": "076d92450e5e697bc6d6f7b92bbe6fa63a3efee94fd8a63e47157052db802e83"
        }
    },
    "installer": {
        "script": [
            "if (!(test-path $persist_dir)) { New-Item -type directory $persist_dir > $null }",
            "$persist_item = Join-Path $persist_dir 'SumatraPDF-settings.txt'",
            "if (!(Test-Path $persist_item)) {",
            "    $source_item  = Join-Path $dir 'SumatraPDF-settings.txt'",
            "    if (Test-Path $source_item) {",
            "        Move-Item -Path $source_item -Destination $persist_item",
            "    } else {",
            "        Set-Content -Path $persist_item 'CheckForUpdates = false' -Encoding Ascii",
            "    }",
            "}",
            "Get-ChildItem \"$dir\\SumatraPDF-*.exe\" | Rename-Item -NewName 'SumatraPDF.exe'"
        ]
    },
    "bin": "SumatraPDF.exe",
    "shortcuts": [
        [
            "SumatraPDF.exe",
            "SumatraPDF"
        ]
    ],
    "persist": [
        "SumatraPDF-settings.txt",
        "sumatrapdfcache"
    ],
    "checkver": {
        "url": "https://files2.sumatrapdfreader.org/software/sumatrapdf/sumatralatest.js",
        "regex": "sumLatestVer\\s*=\\s*([\\d]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.sumatrapdfreader.org/dl/prerel/$version/SumatraPDF-prerel-64.exe"
            },
            "arm64": {
                "url": "https://www.sumatrapdfreader.org/dl/prerel/$version/SumatraPDF-prerel-arm64.exe"
            }
        }
    }
}
