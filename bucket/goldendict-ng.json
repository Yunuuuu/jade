{
    "version": "26.6.0",
    "description": "A feature-rich dictionary lookup program",
    "homepage": "https://github.com/xiaoyifang/goldendict-ng",
    "license": "GPL-3.0-only",
    "url": "https://github.com/xiaoyifang/goldendict-ng/releases/download/v26.6.0/GoldenDict-ng-26.6.0-Qt6.10.3-Windows.7z",
    "hash": "8db2d0f5eef5555ab67e87a599034bc4c47d99e1d32e44c59d9a17d87be6b7f3",
    "extract_dir": "GoldenDict-ng-26.6.0-Qt6.10.3-Windows",
    "bin": "GoldenDict.exe",
    "shortcuts": [
        [
            "GoldenDict.exe",
            "GoldenDict"
        ]
    ],
    "persist": [
        "portable",
        "content"
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'GoldenDict-ng'),",
        "        (Join-Path $env:LOCALAPPDATA 'GoldenDict-ng')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging GoldenDict-ng data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/xiaoyifang/goldendict-ng/releases/latest",
        "script": [
            "$assets = json_path $page \"$.assets[?(@.name =~ /Windows\\.7z$/)]\"",
            "$url = json_path $assets \"$[0].browser_download_url\"",
            "$version = json_path $page $.tag_name",
            "Write-Output \"$version $url\""
        ],
        "regex": "^v(?<Version>[\\d.]+) (?<Url>https://.+/(?<Basename>.+)\\.7z)$",
        "replace": "${Version}"
    },
    "autoupdate": {
        "url": "$matchUrl",
        "hash": {
            "mode": "github"
        },
        "extract_dir": "$matchBasename"
    }
}
