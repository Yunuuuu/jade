{
    "version": "0.70.0",
    "description": "A fast reverse proxy to help you expose a local server behind a NAT or firewall to the internet.",
    "homepage": "https://github.com/fatedier/frp",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/fatedier/frp/releases/download/v0.70.0/frp_0.70.0_windows_amd64.zip",
            "hash": "8407f83429643aa3fa9590d0c87a46b1ac14660efb96e46c955a4c2802f744b0",
            "extract_dir": "frp_0.70.0_windows_amd64"
        },
        "arm64": {
            "url": "https://github.com/fatedier/frp/releases/download/v0.70.0/frp_0.70.0_windows_arm64.zip",
            "hash": "ee4ebec11f61129935cac67dbb56d70fc28bc3176f6b92c1fbef84e05f8c6ebb",
            "extract_dir": "frp_0.70.0_windows_arm64"
        }
    },
    "installer": {
        "script": [
            "if (!(test-path $persist_dir)) { New-Item -type directory $persist_dir > $null }",
            "$dir_items = @(",
            "    'frpc.toml',",
            "    'frps.toml'",
            ")",
            "foreach ($item in $dir_items) {",
            "    $persist_item = Join-Path $persist_dir $item",
            "    if (!(Test-Path $persist_item)) {",
            "        $source_item  = Join-Path $dir $item",
            "        if (Test-Path $source_item) {",
            "            Move-Item -Path $source_item -Destination $persist_item",
            "        } else {",
            "            New-Item -ItemType Directory -Path $persist_item | Out-Null",
            "        }",
            "    }",
            "}"
        ]
    },
    "bin": [
        "frpc.exe",
        "frps.exe"
    ],
    "persist": [
        "frpc.toml",
        "frps.toml"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/fatedier/frp/releases/download/v$version/frp_$version_windows_amd64.zip",
                "extract_dir": "frp_$version_windows_amd64"
            },
            "arm64": {
                "url": "https://github.com/fatedier/frp/releases/download/v$version/frp_$version_windows_arm64.zip",
                "extract_dir": "frp_$version_windows_arm64"
            }
        },
        "hash": {
            "url": "$baseurl/frp_sha256_checksums.txt"
        }
    }
}
