{
    "version": "2.0.5",
    "description": "A fork of the discontinued Switch emulator, Ryujinx.",
    "homepage": "https://git.ryujinx.app/projects/Ryubing",
    "license": "MIT",
    "notes": [
        "ATTENTION: Ryujinx requires Nintendo Switch firmware and a prod.keys file to function.",
        "Learn more at https://docs.ryujinx.app/guides/setup-guide/",
        "Following site may be useful, use them at your own risk:",
        "  1. https://theprodkeys.com/vi/",
        "  2. https://prodkeys.net/"
    ],
    "architecture": {
        "64bit": {
            "url": "https://git.ryujinx.app/projects/Kenji-NX/releases/download/2.0.5/kenjinx-2.0.5-win_x64.zip",
            "hash": "a8c0c127019ba973d04db014998f5f459c7bf4614b985ecd0d0a94ee1f3f746b"
        },
        "arm64": {
            "url": "https://git.ryujinx.app/projects/Kenji-NX/releases/download/2.0.5/kenjinx-2.0.5-win_arm64.zip",
            "hash": "a428bab7099b0fbf23d4a1a7a867c7b831fecdbf0796bc04fefad2d0b261b57d"
        }
    },
    "extract_dir": "publish",
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-Item \"$persist_dir\\portable\" -ItemType Directory | Out-Null",
        "   if (Test-Path \"$env:APPDATA\\Ryujinx\") {",
        "       Write-host \"Migrating AppData...\" -ForegroundColor yellow",
        "       Copy-Item -Path \"$env:APPDATA\\Ryujinx\\*\" -Destination \"$persist_dir\\portable\" -Recurse",
        "       Remove-Item -Path \"$env:APPDATA\\Ryujinx\" -Recurse",
        "   }",
        "}"
    ],
    "bin": [
        [
            "Ryujinx.exe",
            "ryubing"
        ]
    ],
    "shortcuts": [
        [
            "Ryujinx.exe",
            "Ryubing"
        ]
    ],
    "persist": "portable",
    "checkver": {
        "url": "https://git.ryujinx.app/projects/Kenji-NX/releases/latest",
        "regex": "releases/tag/([0-9.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://git.ryujinx.app/projects/Kenji-NX/releases/download/$version/kenjinx-$version-win_x64.zip"
            },
            "arm64": {
                "url": "https://git.ryujinx.app/projects/Kenji-NX/releases/download/$version/kenjinx-$version-win_arm64.zip"
            }
        }
    }
}
