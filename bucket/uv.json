{
    "version": "0.11.24",
    "description": "An extremely fast Python package installer and resolver, written in Rust.",
    "homepage": "https://docs.astral.sh/uv/",
    "license": "Apache-2.0|MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.24/uv-x86_64-pc-windows-msvc.zip",
            "hash": "af9573a2e36f7020b18ec5fdde20117aae74bbad3f4acb3dc3fc03319f1aa083"
        },
        "32bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.24/uv-i686-pc-windows-msvc.zip",
            "hash": "1df231a0da08d691c32047cce8a4aa0aba82d2a74f02999f2e4847a5e8e7e2df"
        },
        "arm64": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.24/uv-aarch64-pc-windows-msvc.zip",
            "hash": "51bcf8051dcc2075fba9136ece0f229205a6ef813e68e5709c6eeb18802afed5"
        }
    },
    "bin": [
        "uv.exe",
        "uvx.exe",
        "uvw.exe"
    ],
    "env_set": {
        "UV_CACHE_DIR": "$persist_dir\\cache",
        "UV_CREDENTIALS_DIR": "$persist_dir\\credentials",
        "UV_PYTHON_INSTALL_DIR": "$persist_dir\\python\\versions",
        "UV_PYTHON_BIN_DIR": "$persist_dir\\python\\shims",
        "UV_TOOL_DIR": "$persist_dir\\tools\\data",
        "UV_TOOL_BIN_DIR": "$persist_dir\\tools\\shims"
    },
    "post_install": [
        "Add-Path -Path $persist_dir\\python\\shims -Global:$global",
        "Add-Path -Path $persist_dir\\tools\\shims -Global:$global"
    ],
    "post_uninstall": [
        "Remove-Path -Path $persist_dir\\python\\shims -Global:$global",
        "Remove-Path -Path $persist_dir\\tools\\shims -Global:$global",
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'uv'),",
        "        (Join-Path $env:LocalAppData 'uv')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging uv data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/astral-sh/uv"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-x86_64-pc-windows-msvc.zip"
            },
            "32bit": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-i686-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
