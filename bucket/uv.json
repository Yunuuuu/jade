{
    "version": "0.11.31",
    "description": "An extremely fast Python package installer and resolver, written in Rust.",
    "homepage": "https://docs.astral.sh/uv/",
    "license": "Apache-2.0|MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.31/uv-x86_64-pc-windows-msvc.zip",
            "hash": "410c2fd3126ff621c9450a21cfc200002c7540dc48d130069a8f619cdb0a811b"
        },
        "32bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.31/uv-i686-pc-windows-msvc.zip",
            "hash": "4b4d07862b81275ea1a507d5e80774b0f38502493f854cbb585a987c0155d627"
        },
        "arm64": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.31/uv-aarch64-pc-windows-msvc.zip",
            "hash": "060da44c6474680ce9ed31f866a496cb06979dbea86de8fe24e0f22c48ac992b"
        }
    },
    "bin": [
        "uv.exe",
        "uvx.exe",
        "uvw.exe"
    ],
    "persist": [
        "home",
        "cache"
    ],
    "env_set": {
        "UV_CACHE_DIR": "$dir\\cache",
        "UV_CREDENTIALS_DIR": "$dir\\home\\credentials",
        "UV_PYTHON_INSTALL_DIR": "$dir\\home\\python\\versions",
        "UV_PYTHON_BIN_DIR": "$dir\\home\\python\\bin",
        "UV_TOOL_DIR": "$dir\\home\\tools\\envs",
        "UV_TOOL_BIN_DIR": "$dir\\home\\tools\\bin"
    },
    "env_add_path": [
        "home\\python\\bin",
        "home\\tools\\bin"
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'uv'),",
        "        (Join-Path $env:LocalAppData 'uv')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging uv data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/astral-sh/uv"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-x86_64-pc-windows-msvc.zip"
            },
            "32bit": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-i686-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
