    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/eitsupi/arf/releases/download/v0.4.3-rc.1/arf-console-x86_64-pc-windows-msvc.zip",
            "hash": "d6296b2367be726740983e4160c5943b9a2909097b5e8953d0e508e5cd59048c"
        },
        "32bit": {
            "url": "https://github.com/eitsupi/arf/releases/download/v0.4.3-rc.1/arf-console-x86_64-pc-windows-msvc.zip",
            "hash": "d6296b2367be726740983e4160c5943b9a2909097b5e8953d0e508e5cd59048c"
        },
        "arm64": {
            "url": "https://github.com/eitsupi/arf/releases/download/v0.4.3-rc.1/arf-console-aarch64-pc-windows-msvc.zip",
            "hash": "708a8f8aa4f544070043186e9fe2ec49f1c9dc01ea6ffc2e0d2f6396ccca89d0"
        }
    },
    "bin": "arf.exe",
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'arf'),",
        "        (Join-Path $env:LOCALAPPDATA 'arf')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging arf data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://github.com/eitsupi/arf/releases",
        "regex": "releases/tag/v([0-9a-zA-Z\\-.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/eitsupi/arf/releases/download/v$version/arf-console-x86_64-pc-windows-msvc.zip"
            },
            "32bit": {
                "url": "https://github.com/eitsupi/arf/releases/download/v$version/arf-console-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/eitsupi/arf/releases/download/v$version/arf-console-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
