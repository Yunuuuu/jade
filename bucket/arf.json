{
    "version": "0.4.2",
    "description": "A modern, cross-platform R console",
    "homepage": "https://github.com/eitsupi/arf",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/eitsupi/arf/releases/download/v0.4.2/arf-console-x86_64-pc-windows-msvc.zip",
            "hash": "ab50192b3cb3867271948d7bb569e7659ea561b385591f4d37cf96d47dcf6477"
        },
        "32bit": {
            "url": "https://github.com/eitsupi/arf/releases/download/v0.4.2/arf-console-x86_64-pc-windows-msvc.zip",
            "hash": "ab50192b3cb3867271948d7bb569e7659ea561b385591f4d37cf96d47dcf6477"
        },
        "arm64": {
            "url": "https://github.com/eitsupi/arf/releases/download/v0.4.2/arf-console-aarch64-pc-windows-msvc.zip",
            "hash": "96abb1239a793796b3f9e79777e0ddb565f6d639351d5ee4cb13f760b0faafb2"
        }
    },
    "bin": "arf.exe",
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'arf'),",
        "        (Join-Path $env:LOCALAPPDATA 'arf')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging arf data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://github.com/eitsupi/arf/releases",
        "regex": "releases/tag/v([0-9a-zA-Z\\-.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/eitsupi/arf/releases/download/v$version/arf-console-x86_64-pc-windows-msvc.zip"
            },
            "32bit": {
                "url": "https://github.com/eitsupi/arf/releases/download/v$version/arf-console-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/eitsupi/arf/releases/download/v$version/arf-console-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
