{
    "version": "4.1.10",
    "description": "Instant messaging app by Tencent",
    "homepage": "https://pc.weixin.qq.com/",
    "license": {
        "identifier": "EULA",
        "url": "https://weixin.qq.com/cgi-bin/readtemplate?lang=zh_CN&t=weixin_agreement&s=default"
    },
    "url": "https://dldir1v6.qq.com/weixin/Universal/Windows/WeChatWin_4.1.10.exe#/dl.7z",
    "pre_install": [
        "$trash_paths = @(",
        "    (Join-Path $dir '$PLUGINSDIR')",
        ")",
        "foreach ($trash_path in $trash_paths) {",
        "    if (Test-Path $trash_path) {",
        "        Remove-Item -Recurse -Force $trash_path",
        "    }",
        "}"
    ],
    "post_install": [
        "$dir_path = \"$dir\".Replace('\\', '\\\\')",
        "$persist_path = \"$persist_dir\".Replace('\\', '\\\\')",
        "'wechat-install-context', 'wechat-uninstall-context' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\jade\\config\\wechat\\$_.reg\") {",
        "        $content = Get-Content \"$bucketsdir\\jade\\config\\wechat\\$_.reg\"",
        "        $content = $content.Replace('$wechat_dir', $dir_path)",
        "        $content = $content.Replace('$persist_dir', $persist_path)",
        "        if ($global) {",
        "            $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE')",
        "        }",
        "        $content | Set-Content -Path \"$dir\\$_.reg\"",
        "    }",
        "}"
    ],
    "shortcuts": [
        [
            "wechat.exe",
            "WeChat"
        ]
    ],
    "uninstaller": {
        "script": [
            "if (Test-Path \"$dir\\wechat-uninstall-context.reg\") {",
            "    reg import \"$dir\\wechat-uninstall-context.reg\"",
            "}"
        ]
    },
    "post_uninstall": [
        "if ($purge) {",
        "    $app_paths = @(",
        "        (Join-Path $env:APPDATA 'Tencent\\WeChat'),",
        "        (Join-Path $env:APPDATA 'Tencent\\WeChatApp'),",
        "        (Join-Path $env:APPDATA 'Tencent\\xwechat'),",
        "        (Join-Path $env:USERPROFILE 'Documents\\xwechat_files'),",
        "        (Join-Path $env:USERPROFILE 'Documents\\WeChat Files')",
        "    )",
        "    foreach ($app_path in $app_paths) {",
        "        if (Test-Path $app_path) {",
        "            Write-Host \"Purging WeChat data: $app_path\"",
        "            Remove-Item -Recurse -Force $app_path",
        "        }",
        "    }",
        "    if (-not (Test-Path -Path \"${env:APPDATA}\\Tencent\\*\")) {",
        "        Remove-Item \"${env:APPDATA}\\Tencent\" -Force -Recurse",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://pc.weixin.qq.com/",
        "regex": "Universal/Windows/WeChatWin_(\\d+\\.\\d+\\.\\d+)"
    },
    "autoupdate": {
        "url": "https://dldir1v6.qq.com/weixin/Universal/Windows/WeChatWin_$version.exe#/dl.7z"
    }
}
